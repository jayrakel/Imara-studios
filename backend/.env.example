PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/imara_studios

# JWT Secrets — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_64_CHARS_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_64_CHARS_LONG_RANDOM_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Resend (Email)
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=noreply@imarastudios.com
RESEND_FROM_NAME=Imara Studios
ADMIN_ALERT_EMAIL=admin@imarastudios.com

# Africa's Talking (SMS) — add credentials when ready
AT_API_KEY=CHANGE_ME
AT_USERNAME=CHANGE_ME
AT_SENDER_ID=IMARA
ADMIN_PHONE=+254700000000

# File Uploads
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=imara-studios-uploads
R2_PUBLIC_URL=https://pub-CHANGE_ME.r2.dev
MAX_FILE_SIZE_MB=20

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Doppler integration note:
# Run: doppler setup --project imara-studios --config dev
# Then: doppler run -- node dist/index.js
